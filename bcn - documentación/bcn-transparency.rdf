        </rdf:type>
        <rdf:type>
            <rdf:Description rdf:about="http://www.w3.org/2000/01/rdf-schema#Class"/>
        </rdf:type>
        <rdfs:label xml:lang="es">ComisionDeBiblioteca</rdfs:label>
        <rdfs:comment xml:lang="es">La comision del congreso encargada de la biblioteca, formada por el presidente de la camara de diputados, el presidente del senado y la directora de la biblioteca.</rdfs:comment>
    </rdf:Description>

        <rdfs:comment xml:lang="es">Indica que un funcionario que tiene un cargo en un periodo, tiene un grado definido por una letra.</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.w3.org/ns/org#hasUnit">

        <rdfs:label xml:lang="es">Caducable</rdfs:label>
        <rdfs:label xml:lang="en">Deprecable</rdfs:label>
    </owl:Class>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#Categoria -->

    <owl:Class rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#Categoria">

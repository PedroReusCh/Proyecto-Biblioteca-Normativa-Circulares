    <!-- http://datos.bcn.cl/ontologies/bcn-resources#crdate -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#crdate">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Indica la fecha de creción en formato YYYY-MM-DD</rdfs:comment>
        <rdfs:label xml:lang="en">creation date</rdfs:label>
        <rdfs:label xml:lang="es">fecha de creación</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#creadaPorWorkflow -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#creadaPorWorkflow">
        <rdfs:comment>Indica si una sesión o legislatura ha sido creada por el worwflow de procesamiento</rdfs:comment>
        <rdfs:label>creada por workflow</rdfs:label>
        <rdfs:label xml:lang="en">created by workflow</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#descripcionXML -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#descripcionXML">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#SeccionRecurso"/>
        <rdfs:comment xml:lang="es">Entrega la descripción en XML de una sección de documento Akoma Ntoso</rdfs:comment>
        <rdfs:label xml:lang="es">descripción en XML</rdfs:label>
        <rdfs:label xml:lang="en">xml description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#editorId -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#editorId">
        <rdfs:comment>Establece un id de tipo texto para recursos referenciados desde diversas marcas en un editor XML</rdfs:comment>
        <rdfs:label xml:lang="en">editor id</rdfs:label>
        <rdfs:label xml:lang="es">id en editor XML</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#metadatoGenerico -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#metadatoGenerico">
        <rdfs:comment>Permite generar metadatos para uso exclusivo el editor XML [Editor XML]</rdfs:comment>
        <rdfs:label xml:lang="en">generic metadata</rdfs:label>
        <rdfs:label xml:lang="es">metadato genérico</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#nerAcronym -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#nerAcronym">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://datos.bcn.cl/ontologies/bcn-biographies#Rol"/>
                    <rdf:Description rdf:about="http://datos.bcn.cl/ontologies/bcn-congress#Evento"/>
                    <rdf:Description rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#ProyectoDeLey"/>
                    <rdf:Description rdf:about="http://dbpedia.org/ontology/Place"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#TemporalEntity"/>
                    <rdf:Description rdf:about="http://www.w3.org/ns/org#FormalOrganization"/>
                    <rdf:Description rdf:about="http://xmlns.com/foaf/0.1/Document"/>
                    <rdf:Description rdf:about="http://xmlns.com/foaf/0.1/Person"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Acrónimo en el NER (marcador automático de entidades)</rdfs:comment>
        <rdfs:comment xml:lang="en">has ner acronym</rdfs:comment>
        <rdfs:label>acrónimo en el NER</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#numero -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#numero">
        <rdfs:comment>Asocia un número (string) identificatorio a un recurso en diversos contextos</rdfs:comment>
        <rdfs:label xml:lang="en">number</rdfs:label>
        <rdfs:label xml:lang="es">número</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#obsoleto -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#obsoleto">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#Caducable"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label xml:lang="en">deprecated</rdfs:label>
        <rdfs:label xml:lang="es">obsoleto</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tempId -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tempId">
        <rdfs:comment>Relaciona un recurso con un id temporal</rdfs:comment>
        <rdfs:label>id temporal</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneAtributoName_Editor -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneAtributoName_Editor">
        <rdfs:comment>Relaciona una URI de un recurso con una etiqueta en XML con la cual es marcada en los documentos Akoma Ntoso [Editor XML]</rdfs:comment>
        <rdfs:label xml:lang="en">has name attribute</rdfs:label>
        <rdfs:label xml:lang="es">tiene atributo name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneFin -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneFin">
        <rdfs:comment>Establece una hora de fin de un evento específico</rdfs:comment>
        <rdfs:label xml:lang="en">has end</rdfs:label>
        <rdfs:label xml:lang="es">tiene fin</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneInicio -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneInicio">
        <rdfs:comment>Establece una hora de inicio de un evento específico</rdfs:comment>
        <rdfs:label xml:lang="en">has init</rdfs:label>
        <rdfs:label xml:lang="es">tiene inicio</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tienePathXML -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tienePathXML">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Document"/>
        <rdfs:comment>Describe en sintaxis XPATH la ubicación de una sección dentro de un documento XML</rdfs:comment>
        <rdfs:label xml:lang="en">has XML path</rdfs:label>
        <rdfs:label xml:lang="es">tiene path XML</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneTerminoLibre -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneTerminoLibre">
        <rdfs:comment>Asocia un recurso a un metadato de texto denominado término libre</rdfs:comment>
        <rdfs:label xml:lang="en">has keyword</rdfs:label>
        <rdfs:label xml:lang="es">tiene término libre</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneURI -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneURI">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#Documento"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:label xml:lang="en">has URI</rdfs:label>
        <rdfs:label xml:lang="es">tiene URI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#totalPareos -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#totalPareos">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment>Indica el número de pareos en la votación</rdfs:comment>
        <rdfs:label xml:lang="es">total de pareos</rdfs:label>
        <rdfs:label xml:lang="en">total of agree abstention</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#totalParlamentariosPareados -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#totalParlamentariosPareados">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment>Indica el número de votantes optaron por pareo en la votación</rdfs:comment>
        <rdfs:label xml:lang="es">total parlamentarios pareados</rdfs:label>
        <rdfs:label xml:lang="en">total parliamentarians in abstention agree</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#totalVotosAFavor -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#totalVotosAFavor">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment>Indica el número de votantes que votaron a favor en la votación</rdfs:comment>
        <rdfs:label xml:lang="es">total de votos a favor</rdfs:label>
        <rdfs:label xml:lang="en">total pro</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#totalVotosEnContra -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#totalVotosEnContra">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment>Indica el número de votantes que votaron en contra en la votación</rdfs:comment>
        <rdfs:label xml:lang="en">total cons</rdfs:label>
        <rdfs:label xml:lang="es">total de votos en contra</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#totalVotosSeAbstiene -->

    <owl:DatatypeProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#totalVotosSeAbstiene">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment>Indica el número de votantes que se abstuvieron en la votación</rdfs:comment>
        <rdfs:label xml:lang="en">total abstention</rdfs:label>
        <rdfs:label xml:lang="es">total de votos de abstención</rdfs:label>
    </owl:DatatypeProperty>
    



<?xml version="1.0"?>
<rdf:RDF xmlns="http://datos.bcn.cl/ontologies/bcn-resources#"
     xml:base="http://datos.bcn.cl/ontologies/bcn-resources"
     xmlns:cc="http://web.resource.org/cc/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:ns="http://www.w3.org/2003/06/sw-vocab-status/ns#"
     xmlns:bio="http://purl.org/vocab/bio/0.1/"
     xmlns:geo="http://www.w3.org/2003/01/geo/wgs84_pos#"
     xmlns:org="http://www.w3.org/ns/org#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:wot="http://xmlns.com/wot/0.1/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:frbr="http://purl.org/vocab/frbr/core#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:time="http://www.w3.org/2006/time#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:bcnbio="http://datos.bcn.cl/ontologies/bcn-biographies#"
     xmlns:bcncon="http://datos.bcn.cl/ontologies/bcn-congress#"
     xmlns:bcnres="http://datos.bcn.cl/ontologies/bcn-resources#"
     xmlns:dbpedia="http://dbpedia.org/ontology/">
    <owl:Ontology rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#">
        <owl:versionIRI rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources/1.2/bcn-resources.rdf"/>
        <owl:imports rdf:resource="http://datos.bcn.cl/ontologies/bcn-biographies#"/>
        <rdfs:comment xml:lang="es">La Ontología de recursos legislativos de la BCN entrega un modelo de clases y propiedades que modelan la estructura jerarquía de los principales recursos referenciables en el Congreso Nacional (tales como documentos y relaciones con actores).</rdfs:comment>
        <rdfs:label xml:lang="es">Ontología de Recursos Legislativos</rdfs:label>
        <owl:versionInfo xml:lang="es">1.2</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://datos.bcn.cl/ontologies/bcn-congress#tieneDocumento -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-congress#tieneDocumento">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-congress#RecursoLegislativo"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#Documento"/>
        <rdfs:comment xml:lang="es">Enlaza un recurso legislativo con un recurso (documento) representado por una URI sintética desde la cual se referenciará tanto la información de la ficha FRBR como la URI del documento real.</rdfs:comment>
        <rdfs:label>tiene documento</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-congress#tieneSeccionRecurso -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-congress#tieneSeccionRecurso">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-congress#RecursoLegislativo"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-congress#SeccionRecurso"/>
        <rdfs:label xml:lang="en">has resource section</rdfs:label>
        <rdfs:label xml:lang="es">tiene seccion recurso</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#convertedTo -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#convertedTo">
        <rdfs:comment>Permite mantener la trazabilidad entre una entidad temporal y una entidad existente a la cual fue atribuida</rdfs:comment>
        <rdfs:label>convertido a</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#creadaPor -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#creadaPor">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#TramitacionProyectoDeLey"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/org#FormalOrganization"/>
        <rdfs:comment>Enlaza una tramitación de proyecto de ley con la organización creadora</rdfs:comment>
        <rdfs:label>creada por</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#esParteDe -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#esParteDe">
        <rdfs:comment>Permite enlazar dos recursos mediante una relación de inclusión S es parte de O</rdfs:comment>
        <rdfs:label xml:lang="es">es parte de</rdfs:label>
        <rdfs:label xml:lang="en">is part of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#estado -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#estado">
        <rdfs:label>estado</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#extraidoDesde -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#extraidoDesde">
        <rdfs:comment>Vincula un documento o una sección del documento con su origen</rdfs:comment>
        <rdfs:label xml:lang="en">extracted from</rdfs:label>
        <rdfs:label xml:lang="es">extraído desde</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#fromTemporalEntity -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#fromTemporalEntity">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#EntidadTemporal"/>
        <rdfs:comment>Relaciona una entidad de tipo persona con su origen en una entidad temporal</rdfs:comment>
        <rdfs:label>extraído desde entidad temporal</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#fuenteDocumento -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#fuenteDocumento">
        <rdfs:range rdf:resource="http://www.w3.org/ns/org#FormalOrganization"/>
        <rdfs:comment>Asocia un documento con la oficina de origen de este</rdfs:comment>
        <rdfs:label xml:lang="en">document source</rdfs:label>
        <rdfs:label xml:lang="es">fuente documento</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#hasExpression -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#hasExpression">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#FichaFRBR"/>
        <rdfs:range rdf:resource="http://purl.org/vocab/frbr/core#Expression"/>
        <rdfs:label xml:lang="en">has expression</rdfs:label>
        <rdfs:label xml:lang="es">tiene expresión</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#hasManifestation -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#hasManifestation">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#FichaFRBR"/>
        <rdfs:range rdf:resource="http://purl.org/vocab/frbr/core#Manifestation"/>
        <rdfs:label xml:lang="en">has manifestation</rdfs:label>
        <rdfs:label xml:lang="es">tiene manifestación</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#hasWork -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#hasWork">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#FichaFRBR"/>
        <rdfs:range rdf:resource="http://purl.org/vocab/frbr/core#Work"/>
        <rdfs:label xml:lang="en">has work</rdfs:label>
        <rdfs:label xml:lang="es">tiene trabajo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#incluidoEn -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#incluidoEn">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Document"/>
        <rdfs:comment>Relaciona un documento con la sección de otro documento donde está incluído de fuente</rdfs:comment>
        <rdfs:label xml:lang="en">included in</rdfs:label>
        <rdfs:label xml:lang="es">incluído en</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#perteneceA -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#perteneceA">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#TipoDocumento"/>
        <rdfs:comment>Permite relacionar una sección de un documento a un tipo de documento Akoma Ntoso [Editor XML]</rdfs:comment>
        <rdfs:label xml:lang="en">belongs to</rdfs:label>
        <rdfs:label xml:lang="es">pertenece A</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneAdhesion -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneAdhesion">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#SeccionRecurso"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment>Indica si una sección  de intervención de un documento presenta adhesiones de algún parlamentario</rdfs:comment>
        <rdfs:label xml:lang="en">has adhesion</rdfs:label>
        <rdfs:label xml:lang="es">tiene adhesión</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneAutor -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneAutor">
        <rdfs:comment>Asocia un documento con su o sus autores/as</rdfs:comment>
        <rdfs:label xml:lang="en">has author</rdfs:label>
        <rdfs:label xml:lang="es">tiene autor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneComision -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneComision">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Document"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/org#FormalOrganization"/>
        <rdfs:comment>Relaciona un documento con una comisión parlamentaria</rdfs:comment>
        <rdfs:label xml:lang="en">has commission</rdfs:label>
        <rdfs:label xml:lang="es">tiene comisión</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneDatosTemporales -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneDatosTemporales">
        <rdfs:comment>Relaciona un recurso con algún dato temporal que debe ser corroborado</rdfs:comment>
        <rdfs:label>tiene datos temporales</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneDocumentoAkomaNtoso -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneDocumentoAkomaNtoso">
        <rdfs:subPropertyOf rdf:resource="http://datos.bcn.cl/ontologies/bcn-congress#tieneDocumento"/>
        <rdfs:comment>Enlaza un recurso con su representación en formato AkomaNtoso XML</rdfs:comment>
        <rdfs:label xml:lang="en">has Akoma Ntoso document</rdfs:label>
        <rdfs:label xml:lang="es">tiene documento Akoma Ntoso</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneDocumentoTXT -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneDocumentoTXT">
        <rdfs:subPropertyOf rdf:resource="http://datos.bcn.cl/ontologies/bcn-congress#tieneDocumento"/>
        <rdfs:comment>Enlaza un recurso con su representación en formato TXT</rdfs:comment>
        <rdfs:label xml:lang="en">has text document</rdfs:label>
        <rdfs:label xml:lang="es">tiene documento de texto</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneEmisor -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneEmisor">
        <rdfs:comment>Relaciona un documento o una sección con una entidad que emite dicho mensaje</rdfs:comment>
        <rdfs:label xml:lang="en">has transmitter</rdfs:label>
        <rdfs:label xml:lang="es">tiene emisor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneEtiquetaXML -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneEtiquetaXML">
        <rdfs:comment>Relaciona una URI de una sección recurso con una URI que representa una etiqueta XML [Editor XML]</rdfs:comment>
        <rdfs:label xml:lang="en">has XML tag</rdfs:label>
        <rdfs:label xml:lang="es">tiene etiqueta XML</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneFichaFRBR -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneFichaFRBR">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#Documento"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#FichaFRBR"/>
        <rdfs:label xml:lang="en">has frbr card</rdfs:label>
        <rdfs:label xml:lang="es">tiene ficha FRBR</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneIniciativa -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneIniciativa">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#ProyectoDeLey"/>
        <rdfs:comment>Describe el tipo de iniciativa que ha tenido un documento, preferentemente un proyecto de ley (moción o mensaje presidencial)</rdfs:comment>
        <rdfs:label xml:lang="en">initiative type</rdfs:label>
        <rdfs:label xml:lang="es">tiene iniciativa</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneItem -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneItem">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#FichaFRBR"/>
        <rdfs:range rdf:resource="http://purl.org/vocab/frbr/core#Item"/>
        <rdfs:label xml:lang="en">has item</rdfs:label>
        <rdfs:label xml:lang="es">tiene ítem</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneMateria -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneMateria">
        <rdfs:range rdf:resource="http://purl.org/vocab/frbr/core#subject"/>
        <rdfs:comment>Asocia un recurso a un metadato normalizado de tipo materia</rdfs:comment>
        <rdfs:label xml:lang="en">has subject</rdfs:label>
        <rdfs:label xml:lang="es">tiene materia</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tienePersona -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tienePersona">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-sessiondaily#Asistente"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment>Enlaza una entidad de asistncia con una persona</rdfs:comment>
        <rdfs:label xml:lang="en">has person</rdfs:label>
        <rdfs:label xml:lang="es">tiene persona</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneProyectoDeLey -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneProyectoDeLey">
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#ProyectoDeLey"/>
        <rdfs:comment>Relaciona un documento o una sección de un documento con un proyecto de ley</rdfs:comment>
        <rdfs:label xml:lang="en">has bill</rdfs:label>
        <rdfs:label xml:lang="es">tiene proyecto de ley</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneReceptor -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneReceptor">
        <rdfs:comment>Relaciona un documento o una parte de un documento con una entidad a la cual está dirigida</rdfs:comment>
        <rdfs:label xml:lang="en">has receiver</rdfs:label>
        <rdfs:label xml:lang="es">tiene receptor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneReferencia -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneReferencia">
        <rdfs:label xml:lang="en">has reference</rdfs:label>
        <rdfs:label xml:lang="es">tiene referencia</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneResultadoDebate -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneResultadoDebate">
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#ResultadoDebate"/>
        <rdfs:comment>Enlaza un debate con su resultado en caso de tenerlo</rdfs:comment>
        <rdfs:label xml:lang="en">has debate result</rdfs:label>
        <rdfs:label xml:lang="es">tiene resultado debate</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneResultadoVotacion -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneResultadoVotacion">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#SeccionRecurso"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#ResultadoVotacion"/>
        <rdfs:comment>Relaciona una votación con su resultado</rdfs:comment>
        <rdfs:label xml:lang="en">has voting result</rdfs:label>
        <rdfs:label xml:lang="es">tiene resultado votación</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneSesion -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneSesion">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#TramitacionProyectoDeLey"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Document"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-congress#SesionParlamentaria"/>
        <rdfs:comment>Enlaza un recurso con una sesión parlamentaria</rdfs:comment>
        <rdfs:label xml:lang="en">has parliamentary session</rdfs:label>
        <rdfs:label xml:lang="es">tiene sesión parlamentaria</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneTipoDocumento -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneTipoDocumento">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#Documento"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#TipoDocumento"/>
        <rdfs:label xml:lang="en">has document type</rdfs:label>
        <rdfs:label xml:lang="es">tiene tipo documento</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneTipoParticipacion -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneTipoParticipacion">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#Participacion"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#TipoParticipacion"/>
        <rdfs:comment>Relaciona una participación parlamentaria con su tipo</rdfs:comment>
        <rdfs:label xml:lang="en">has speech type</rdfs:label>
        <rdfs:label xml:lang="es">tiene tipo participacion</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneTramitacion -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneTramitacion">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#ProyectoDeLey"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#TramitacionProyectoDeLey"/>
        <rdfs:comment>Asocia un documento con la tramitación de un proyecto de ley a la cual está relacionada o donde fue presentado</rdfs:comment>
        <rdfs:label xml:lang="en">has processing</rdfs:label>
        <rdfs:label xml:lang="es">tiene tramitación</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneTramiteConstitucional -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneTramiteConstitucional">
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-bills#TramiteConstitucional"/>
        <rdfs:comment>Enlaza un documento o proyecto de ley a un trámite constitucional específico</rdfs:comment>
        <rdfs:label xml:lang="en">has constitutional procedure</rdfs:label>
        <rdfs:label xml:lang="es">tiene trámite constitucional</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneTramiteReglamentario -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneTramiteReglamentario">
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-bills#TramiteReglamentario"/>
        <rdfs:comment>Enlaza un documento o proyecto de ley a un trámite reglamentario específico</rdfs:comment>
        <rdfs:label xml:lang="en">has regulatory procedure</rdfs:label>
        <rdfs:label xml:lang="es">tiene trámite reglamentario</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneTrazabilidad -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneTrazabilidad">
        <rdfs:comment>Indica el origen desde donde surge cierto nuevo recurso</rdfs:comment>
        <rdfs:label>tiene trazablidad</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneVotacion -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneVotacion">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#ProyectoDeLey"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#VotacionProyectoDeLey"/>
        <rdfs:comment>Vincula cada una de las votaciones de un proyecto de ley a su proyecto respectivo</rdfs:comment>
        <rdfs:label xml:lang="en">has voting</rdfs:label>
        <rdfs:label xml:lang="es">tiene votación</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tieneVoto -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tieneVoto">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#VotacionProyectoDeLey"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#VotoProyectoDeLey"/>
        <rdfs:comment>Vincula con la votación a cada voto emitido</rdfs:comment>
        <rdfs:label xml:lang="en">has vote</rdfs:label>
        <rdfs:label xml:lang="es">tiene voto</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tipoProyecto -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tipoProyecto">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#ProyectoDeLey"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-bills#TipoProyectoDeLey"/>
        <rdfs:comment>Asocia un proyecto de ley con su tipo</rdfs:comment>
        <rdfs:label xml:lang="en">has bill type</rdfs:label>
        <rdfs:label xml:lang="es">tipo proyecto</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#tipoVotacion -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#tipoVotacion">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#VotacionProyectoDeLey"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#TipoVotacionProyectoDeLey"/>
        <rdfs:comment>Vincula para cada votación el tipo al cual está asociado</rdfs:comment>
        <rdfs:label xml:lang="en">has voting type</rdfs:label>
        <rdfs:label xml:lang="es">tipo votación</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#valorVoto -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#valorVoto">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#VotoProyectoDeLey"/>
        <rdfs:range rdf:resource="http://datos.bcn.cl/ontologies/bcn-sessiondaily#ValoresVoto"/>
        <rdfs:comment>Vincula al voto con su valor</rdfs:comment>
        <rdfs:label xml:lang="es">valor voto</rdfs:label>
        <rdfs:label xml:lang="en">vote value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#votante -->

    <owl:ObjectProperty rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#votante">
        <rdfs:domain rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#VotoProyectoDeLey"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment>Vincula al voto con la persona que lo emite</rdfs:comment>
        <rdfs:label xml:lang="es">votante</rdfs:label>
        <rdfs:label xml:lang="en">voter</rdfs:label>
    </owl:ObjectProperty>
    



        <rdfs:label xml:lang="en">Category</rdfs:label>
        <rdfs:label xml:lang="es">Categoría</rdfs:label>
    </owl:Class>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#Cuenta -->

    <owl:Class rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#Cuenta">
        <rdfs:subClassOf rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#RecursoLegislativo"/>
        <rdfs:label xml:lang="en">Account</rdfs:label>
    </owl:Class>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#DiarioDeSesion -->

    <owl:Class rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#DiarioDeSesion">
        <rdfs:subClassOf rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#RecursoLegislativo"/>
        <rdfs:comment xml:lang="es">Publicación oficial que recoge el debate de las sesiones de sala de cada una de las cámaras, y que se divide fundamentalmente en dos partes: debate en sala y anexo documentos. En el primero, consta el debate en sala propiamente tal, y en el segundo los documentos de que se da cuenta en la sesión respectiva, por ejemplo: los informes evacuados por las Comisiones, los oficios producidos en el proceso legislativo, oficios enviados por órganos externos al Congreso Nacional, informes de comisión investigadora, etc. Se publica un Diario por cada sesión.  </rdfs:comment>
        <rdfs:label xml:lang="es">Diario de sesión</rdfs:label>
        <rdfs:label xml:lang="en">Session daily</rdfs:label>
    </owl:Class>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#DiscusionEnSala -->

    <owl:Class rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#DiscusionEnSala">
        <rdfs:subClassOf rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#RecursoLegislativo"/>
        <rdfs:label xml:lang="es">Discusión en sala</rdfs:label>
        <rdfs:label xml:lang="en">Session room discussion</rdfs:label>
    </owl:Class>
    


    <!-- http://datos.bcn.cl/ontologies/bcn-resources#DiscusionGeneral -->

    <owl:Class rdf:about="http://datos.bcn.cl/ontologies/bcn-resources#DiscusionGeneral">
        <rdfs:subClassOf rdf:resource="http://datos.bcn.cl/ontologies/bcn-resources#DiscusionEnSala"/>
        <rdfs:label xml:lang="es">Discusión general</rdfs:label>
        <rdfs:label xml:lang="en">General discussion</rdfs:label>
